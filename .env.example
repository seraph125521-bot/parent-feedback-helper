# DeepSeek 接入所需的环境变量
# 在 Vercel 项目 Settings → Environment Variables 里配置同名变量；
# 本地用 `vercel dev` 调试时，复制本文件为 .env.local 并填入真实值。
# 注意：.env.local 含密钥，切勿提交到 Git。

# 必填：DeepSeek 控制台申请的密钥
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# 选填：模型名，默认 deepseek-chat
DEEPSEEK_MODEL=deepseek-chat

# 选填：API 地址，默认 https://api.deepseek.com
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 智谱 AI（可选，当前 GitHub Pages 直连版本需在 llm.js 中填写）
# OpenAI 兼容地址：https://open.bigmodel.cn/api/paas/v4/chat/completions
# 常用免费/低价模型：glm-4-flash
ZHIPU_API_KEY=your-zhipu-api-key
ZHIPU_MODEL=glm-4-flash

# API 防滥用与成本保护（选填，使用默认值也可）
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_PER_HOUR=300
MAX_MESSAGES=12
MAX_CONTENT_CHARS=4000
MAX_TOKENS_CAP=800
UPSTREAM_TIMEOUT_MS=30000
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_COOLDOWN_MS=60000
